  "questions": [
    {
      "id": 1,
      "text": "Когда в классе или компании что-то происходит, ты чаще",
      "options": [
        {
          "value": "A",
          "label": "сразу включаешься, что-то предлагаешь"
        },
        {
          "value": "B",
          "label": "сначала наблюдаешь и понимаешь, что к чему"
        }
      ]
    },
    {
      "id": 2,
      "text": "Что ты легче запоминаешь?",
      "options": [
        {
          "value": "A",
          "label": "Детали, факты, что где было"
        },
        {
          "value": "B",
          "label": "Общий смысл и идею"
        }
      ]
    },
    {
      "id": 3,
      "text": "Когда ты споришь, ты скорее…",
      "options": [
        {
          "value": "A",
          "label": "Будешь отстаивать своё мнение до конца"
        },
        {
          "value": "B",
          "label": "Остановишься, если видишь, что человеку неприятно"
        }
      ]
    },
    {
      "id": 4,
      "text": "Когда тебе дают задание, ты",
      "options": [
        {
          "value": "A",
          "label": "хочешь чёткие правила и сроки"
        },
        {
          "value": "B",
          "label": "предпочитаешь свободу и возможность менять план"
        }
      ]
    },
    {
      "id": 5,
      "text": "В новой компании ты обычно",
      "options": [
        {
          "value": "A",
          "label": "быстро находишь, с кем поговорить"
        },
        {
          "value": "B",
          "label": "держишься спокойнее и не спешишь сближаться"
        }
      ]
    },
    {
      "id": 6,
      "text": "Тебя больше цепляет...",
      "options": [
        {
          "value": "A",
          "label": "мелкие детали и подробности"
        },
        {
          "value": "B",
          "label": "общая картина и направление"
        }
      ]
    },
    {
      "id": 7,
      "text": "Если друг просит совета, ты скорее…",
      "options": [
        {
          "value": "A",
          "label": "Скажешь, как лучше поступить на самом деле"
        },
        {
          "value": "B",
          "label": "Поддержишь, даже если он не совсем прав"
        }
      ]
    },
    {
      "id": 8,
      "text": "Если что-то не по плану, ты...",
      "options": [
        {
          "value": "A",
          "label": "слегка раздражаешься"
        },
        {
          "value": "B",
          "label": "легко перестраиваешься"
        }
      ]
    },
    {
      "id": 9,
      "text": "После общения с людьми ты чаще...",
      "options": [
        {
          "value": "A",
          "label": "ты чувствуешь подъем и заряд"
        },
        {
          "value": "B",
          "label": "чувствуешь усталость и хочешь побыть один"
        }
      ]
    },
    {
      "id": 10,
      "text": "Тебе быстрее становится скучнее, когда...",
      "options": [
        {
          "value": "A",
          "label": "много говорят без примеров"
        },
        {
          "value": "B",
          "label": "все слишком подробно и буквально"
        }
      ]
    },
    {
      "id": 11,
      "text": "Когда кто-то ошибается, ты чаще",
      "options": [
        {
          "value": "A",
          "label": "указываешь на ошибку напрямую"
        },
        {
          "value": "B",
          "label": "стараешься не задеть человека"
        }
      ]
    },
    {
      "id": 12,
      "text": "Когда у тебя есть дело, ты чаще...",
      "options": [
        {
          "value": "A",
          "label": "хочешь сделать его сразу и закрыть"
        },
        {
          "value": "B",
          "label": "можешь отложить и делать по настроению"
        }
      ]
    },
    {
      "id": 13,
      "text": "В группе ты чаще",
      "options": [
        {
          "value": "A",
          "label": "берёшь инициативу"
        },
        {
          "value": "B",
          "label": "выполняешь свою часть тихо и точно"
        }
      ]
    },
    {
      "id": 14,
      "text": "Когда ты что-то вспоминаешь, у тебя в голове чаще...",
      "options": [
        {
          "value": "A",
          "label": "картинка того, что было"
        },
        {
          "value": "B",
          "label": "мысль или вывод"
        }
      ]
    },
    {
      "id": 15,
      "text": "В конфликте ты скорее…",
      "options": [
        {
          "value": "A",
          "label": "Ищешь, кто прав и кто ошибся"
        },
        {
          "value": "B",
          "label": "Ищешь, как всех помирить"
        }
      ]
    },
    {
      "id": 16,
      "text": "Тебе проще учиться, когда",
      "options": [
        {
          "value": "A",
          "label": "есть чёткий план и структура"
        },
        {
          "value": "B",
          "label": "можно идти в своём темпе"
        }
      ]
    },
    {
      "id": 17,
      "text": "В классе или группе ты чаще...",
      "options": [
        {
          "value": "A",
          "label": "легко привлекаешь к себе внимание"
        },
        {
          "value": "B",
          "label": "стараешься не быть в центре"
        }
      ]
    },
    {
      "id": 18,
      "text": "Ты чаще замечаешь",
      "options": [
        {
          "value": "A",
          "label": "детали и конкретные вещи"
        },
        {
          "value": "B",
          "label": "общую картину и смысл"
        }
      ]
    },
    {
      "id": 19,
      "text": "Для тебя важнее…",
      "options": [
        {
          "value": "A",
          "label": "справедливость и логика"
        },
        {
          "value": "B",
          "label": "гармония и чувства людей"
        }
      ]
    },
    {
      "id": 20,
      "text": "Перед выходом из дома ты...",
      "options": [
        {
          "value": "A",
          "label": "собираешься заранее"
        },
        {
          "value": "B",
          "label": "делаешь все в последний момент"
        }
      ]
    },
    {
      "id": 21,
      "text": "Одиночество для тебя - это чаще...",
      "options": [
        {
          "value": "A",
          "label": "скучно и не хватает людей"
        },
        {
          "value": "B",
          "label": "нормально или даже комфортно"
        }
      ]
    },
    {
      "id": 22,
      "text": "Если ты гуляешь один/одна, ты больше...",
      "options": [
        {
          "value": "A",
          "label": "смотришь вокруг"
        },
        {
          "value": "B",
          "label": "думаешь о своем"
        }
      ]
    },
    {
      "id": 23,
      "text": "В конфликтной ситуации ты",
      "options": [
        {
          "value": "A",
          "label": "стараешься разобраться логически"
        },
        {
          "value": "B",
          "label": "стараешься сохранить отношения"
        }
      ]
    },
    {
      "id": 24,
      "text": "Если договорились о времени, ты...",
      "options": [
        {
          "value": "A",
          "label": "стараешься прийти точно"
        },
        {
          "value": "B",
          "label": "относишься к этому гибко"
        }
      ]
    },
    {
      "id": 25,
      "text": "В школьных проектах ты чаще",
      "options": [
        {
          "value": "A",
          "label": "активно обсуждаешь и предлагаешь идеи"
        },
        {
          "value": "B",
          "label": "работаешь молча, но глубоко"
        }
      ]
    },
    {
      "id": 26,
      "text": "Когда ты рассказываешь историю, ты больше...",
      "options": [
        {
          "value": "A",
          "label": "описываешь события"
        },
        {
          "value": "B",
          "label": "делишься мыслями и выводами"
        }
      ]
    },
    {
      "id": 27,
      "text": "В споре для тебя важнее...",
      "options": [
        {
          "value": "A",
          "label": "доказать свою правоту фактами и аргументами"
        },
        {
          "value": "B",
          "label": "не обидеть человека и сохранить нормальные отношения"
        }
      ]
    },
    {
      "id": 28,
      "text": "Тебе спокойнее, когда",
      "options": [
        {
          "value": "A",
          "label": "есть план и понятный порядок"
        },
        {
          "value": "B",
          "label": "есть свобода и можно решать по ходу"
        }
      ]
    }
